#!/bin/sh
set -e
BASE_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
export MAVEN_PROJECTBASEDIR="$BASE_DIR"
WRAPPER_DIR="$BASE_DIR/.mvn/wrapper"
JAR="$WRAPPER_DIR/maven-wrapper.jar"

if [ ! -f "$JAR" ]; then
  mkdir -p "$WRAPPER_DIR"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$(grep wrapperUrl "$WRAPPER_DIR/maven-wrapper.properties" | cut -d= -f2-)" -o "$JAR"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$(grep wrapperUrl "$WRAPPER_DIR/maven-wrapper.properties" | cut -d= -f2-)" -O "$JAR"
  else
    echo "curl or wget is required to download the Maven wrapper jar."
    exit 1
  fi
fi

exec java -Dmaven.multiModuleProjectDirectory="$BASE_DIR" -classpath "$JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"
